# Reason Ready — node configuration (environment file).
# Copy to ~/.config/rrf/config.env (rootless) or /etc/rrf/config.env and edit.

# ---- identity & network ----------------------------------------------------
# This node's a2a identity on the mesh.
RRF_NODE=rrf-1
# Persistent estate path (RocksDB directory; created if missing).
RRF_ESTATE=/var/lib/rrf/estate
# a2a layer-2 listener (warp point address). Unset to disable the network.
RRF_LISTEN=0.0.0.0:7878
# Ops HTTP surface: prometheus /metrics + /healthz /livez /readyz. Unset to disable.
RRF_OPS_ADDR=0.0.0.0:9090
# DuckDB-ready JSONL event stream. Unset to disable.
RRF_EVENTS=/var/lib/rrf/events.jsonl
# Log filter.
RUST_LOG=info
# Capability token: when set, every a2a message except ping must bear it.
# RRF_TOKEN=change-me
# Strict mode: apply resource quotas (payload/top_k/batch caps).
# RRF_STRICT=1

# ---- model backends (see docs/MODELS.md) -----------------------------------
# Which embedder to load. One of:
#   deterministic  — the zero-weight default (dev/CI only; NOT semantic)
#   candle-qwen    — real Qwen embedding backbone via candle (needs weights)
#   onnx           — an ONNX embedding model via ort (needs weights)
#   remote         — call an external embedding endpoint over a2a/HTTP
# RRF_EMBEDDER=candle-qwen
# Path to the embedder weights dir (.safetensors + tokenizer.json + config.json).
# RRF_EMBEDDER_WEIGHTS=/var/lib/rrf/models/qwen3-embedding-0.6b
# Force output dimensionality (else read from the model config).
# RRF_EMBEDDER_DIM=1024

# Which reranker to load. One of: none | candle-nemotron | onnx | remote
# RRF_RERANKER=candle-nemotron
# RRF_RERANKER_WEIGHTS=/var/lib/rrf/models/nemotron-reranker

# Inference device: cpu | cuda:0 | metal. Default cpu.
# RRF_DEVICE=cuda:0
# Embedding batch size (throughput vs latency).
# RRF_EMBED_BATCH=32
