# Reason Ready — systemd unit.
#   install -m644 deploy/rrf.service /etc/systemd/system/rrf.service
#   install -m640 deploy/config.env.example /etc/rrf/config.env   # then edit
#   systemctl enable --now rrf
[Unit]
Description=Reason Ready engine (rrf)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/rrf/config.env
ExecStart=/usr/local/bin/rrf
Restart=on-failure
RestartSec=2
# The daemon handles SIGTERM cleanly: drains, commits the RRD baseline.
KillSignal=SIGTERM
TimeoutStopSec=30
DynamicUser=yes
StateDirectory=rrf
NoNewPrivileges=yes
ProtectSystem=strict
ReadWritePaths=/var/lib/rrf

[Install]
WantedBy=multi-user.target
