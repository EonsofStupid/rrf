# Reason Ready — OCI image, built with Podman (rootless-friendly, multi-stage).
#
#   podman build -f deploy/Containerfile -t localhost/rrf:latest .
#
# The `candle` feature is OFF here (weightless default image). For a
# model-backed image, build with:
#   podman build -f deploy/Containerfile --build-arg FEATURES=candle -t localhost/rrf:candle .
# and mount weights at runtime (see deploy/rrf.container).

FROM docker.io/library/rust:1-bookworm AS build
ARG FEATURES=""
RUN apt-get update && apt-get install -y --no-install-recommends clang libclang-dev && rm -rf /var/lib/apt/lists/*
WORKDIR /src
COPY . .
RUN if [ -n "$FEATURES" ]; then \
        cargo build --release --features "$FEATURES" --bin rrf --bin rrf-bench ; \
    else \
        cargo build --release --bin rrf --bin rrf-bench ; \
    fi

FROM docker.io/library/debian:bookworm-slim
# Rootless: the container runs as an unprivileged uid; podman maps it via
# user namespaces. No USER root work beyond dir creation.
RUN useradd --system --uid 10001 --home /var/lib/rrf rrf \
    && mkdir -p /var/lib/rrf /var/lib/rrf/models && chown -R rrf /var/lib/rrf
COPY --from=build /src/target/release/rrf /src/target/release/rrf-bench /usr/local/bin/
USER 10001
ENV RRF_ESTATE=/var/lib/rrf/estate \
    RRF_LISTEN=0.0.0.0:7878 \
    RRF_EVENTS=/var/lib/rrf/events.jsonl \
    RRF_OPS_ADDR=0.0.0.0:9090 \
    RUST_LOG=info
EXPOSE 7878 9090
VOLUME /var/lib/rrf
ENTRYPOINT ["/usr/local/bin/rrf"]
